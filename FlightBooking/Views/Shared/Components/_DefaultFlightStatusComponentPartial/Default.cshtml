<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Barlow+Condensed:wght@300;400;600;700&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css">

<style>
    /* ── CSS Variables ── */
    :root {
        --burgundy-deep: #1e0b11; /* Ana dış arka plan biraz daha yumuşatıldı */
        --burgundy-mid: #2d121b; /* Tablo içi genel zemin rengi açıldı */
        --burgundy-light: #3d1b26; /* Satırların (Row) temel rengi görünür yapıldı */
        --burgundy-glow: #661d2b; /* Aktif tab butonu içi canlı kızıl */
        --accent-amber: #f3c663;
        --accent-amber-dim: rgba(243, 198, 99, 0.1);
        /* Yazıların yeni arka planda parlaması için kontrast ayarı */
        --text-primary: #ffffff;
        --text-dim: #f3e8eb;
        --border: rgba(243, 198, 99, 0.4); /* Border hatları daha belirgin */
        --text-muted: rgba(245, 240, 230, 0.45);       
        --border-subtle: rgba(245, 240, 230, 0.08);
        --glass: rgba(255, 255, 255, 0.02);
        --glass-hover: rgba(255, 255, 255, 0.06);
        /* Status colours */
        --s-green: #4ade80;
        --s-blue: #38bdf8;
        --s-orange: #fb923c;
        --s-red: #f87171;
        --s-yellow: #facc15;
        --s-purple: #c084fc;
        --s-gray: #cbd5e1;
    }

    /* ── Section shell ── */
    .brand-area.brand-bg {
        /* !important eklenerek dış CSS'lerin bu asil gradienti ezmesi engellendi */
        background: linear-gradient(165deg, #0a0305 0%, #16070c 40%, #250b13 100%) !important;
        padding: 64px 0 72px;
        position: relative;
        overflow: hidden;
        font-family: 'Barlow', sans-serif;
    }

        /* Decorative scanline overlay */
        .brand-area.brand-bg::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: repeating-linear-gradient( 0deg, transparent, transparent 3px, rgba(0,0,0,.18) 3px, rgba(0,0,0,.18) 4px );
            pointer-events: none;
            z-index: 0;
        }

        /* Ambient glow orbs */
        .brand-area.brand-bg::after {
            content: '';
            position: absolute;
            width: 600px;
            height: 600px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(88, 3, 38, 0.55) 10%, transparent 60%);
            top: -200px;
            right: -150px;
            pointer-events: none;
            z-index: 0;
        }

    .fsd-glow-left {
        position: absolute;
        width: 400px;
        height: 400px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(243, 198, 99, 0.06) 0%, transparent 70%);
        bottom: -150px;
        left: -100px;
        pointer-events: none;
        z-index: 0;
    }

    .fsd-container {
        position: relative;
        z-index: 1;
    }

    /* ── Header area ── */
    .fsd-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 36px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .fsd-eyebrow {
        font-family: 'Share Tech Mono', monospace;
        font-size: 12px;
        letter-spacing: .25em;
        color: var(--accent-amber);
        text-transform: uppercase;
        margin-bottom: 6px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .fsd-eyebrow::before {
            content: '';
            display: inline-block;
            width: 20px;
            height: 1px;
            background: var(--accent-amber);
        }

    .fsd-title {
        font-family: 'Barlow Condensed', sans-serif;
        font-size: clamp(28px, 4vw, 42px);
        font-weight: 700;
        color: var(--text-primary);
        letter-spacing: .02em;
        line-height: 1;
        margin: 0;
        text-transform: uppercase;
    }

    .fsd-live-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        background: rgba(74, 222, 128, 0.1);
        border: 1px solid rgba(74, 222, 128, 0.3);
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: .1em;
        color: var(--s-green);
        text-transform: uppercase;
        font-family: 'Share Tech Mono', monospace;
    }

    .fsd-live-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--s-green);
        animation: pulse-dot 2s infinite;
    }

    @@keyframes pulse-dot {
        0%, 100%

    {
        opacity: 1;
        transform: scale(1);
    }

    50% {
        opacity: .4;
        transform: scale(0.8);
    }

    }

    /* ── Tabs ── */
    .fsd-tabs {
        display: flex;
        gap: 6px;
        background: rgba(0,0,0,0.4) !important;
        border: 1px solid var(--border) !important;
        border-radius: 12px;
        padding: 5px;
        margin-bottom: 24px;
        width: fit-content;
    }

    .fsd-tab-btn {
        font-family: 'Barlow Condensed', sans-serif;
        font-size: 15px;
        font-weight: 600;
        letter-spacing: .05em;
        text-transform: uppercase;
        color: var(--text-dim);
        background: transparent;
        border: none;
        border-radius: 8px;
        padding: 10px 32px;
        cursor: pointer;
        transition: all .2s ease;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .fsd-tab-btn i {
            font-size: 15px;
        }

        .fsd-tab-btn:hover {
            color: var(--text-primary);
            background: var(--glass-hover);
        }

        .fsd-tab-btn.active {
            background: linear-gradient(135deg, var(--burgundy-glow), var(--burgundy-light)) !important;
            color: var(--accent-amber) !important;
            border: 1px solid rgba(243, 198, 99, 0.3);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
        }

    /* ── Stats bar ── */
    .fsd-stats {
        display: flex;
        gap: 24px;
        margin-bottom: 20px;
        flex-wrap: wrap;
        background: rgba(0, 0, 0, 0.25);
        padding: 10px 16px;
        border-radius: 8px;
        width: fit-content;
        border: 1px solid var(--border-subtle);
    }

    .fsd-stat {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        color: var(--text-dim);
        font-family: 'Share Tech Mono', monospace;
    }

    .fsd-stat-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    /* ── Table wrapper ── */
    .fsd-table-wrap {
        overflow-x: auto;
        border-radius: 14px;
        border: 1px solid var(--border);
        background: rgba(5, 2, 3, 0.75) !important;
        box-shadow: 0 12px 40px rgba(0,0,0,0.6);
        backdrop-filter: blur(8px);
    }

    /* ── Column header row ── */
    /* ── Tablo Header Arka Planı (Açık ve Belirgin Yapıldı) ── */
    .fsd-col-headers {
        display: grid;
        grid-template-columns: 200px 110px 1fr 1fr 110px 90px 90px 160px;
        gap: 0;
        padding: 14px 24px;
        border-bottom: 2px solid var(--border);
        background: #3a1522 !important; /* Kapkara yerine asil bir mürdüm tonu */
    }

    .fsd-col-label {
        font-family: 'Share Tech Mono', monospace;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: .15em;
        text-transform: uppercase;
        color: var(--accent-amber) !important;
        white-space: nowrap;
        opacity: 0.95;
    }

    /* ── Satırların (Row) Yeni Arka Plan Tonları ── */
    .fsd-flight-row {
        display: grid;
        grid-template-columns: 200px 110px 1fr 1fr 110px 90px 90px 160px;
        gap: 0;
        padding: 16px 24px;
        border-bottom: 1px solid var(--border-subtle);
        align-items: center;
        transition: background .2s ease;
        cursor: default;
        position: relative;
        /* Satırların arka planı artık çok daha görünür ve açık */
        background: rgba(255, 255, 255, 0.05) !important;
    }

        .fsd-flight-row:last-child {
            border-bottom: none;
        }

        .fsd-flight-row::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 4px;
            border-radius: 0 4px 4px 0;
            background: transparent;
            transition: background .2s ease;
        }

        /* Satırın üzerine gelince (Hover) bir tık daha parlaması için */
        .fsd-flight-row:hover {
            background: rgba(255, 255, 255, 0.12) !important;
        }

            .fsd-flight-row:hover::before {
                background: var(--accent-amber);
            }

    /* Cells */
    .fsd-cell {
        padding-right: 12px;
        display: flex;
        align-items: center;
        min-width: 0;
    }

    /* Airline cell */
    .fsd-airline {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .fsd-airline-icon {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        flex-shrink: 0;
        font-weight: 700;
        font-family: 'Barlow Condensed', sans-serif;
        letter-spacing: 0;
        box-shadow: inset 0 0 0 1px rgba(255,255,255,0.15);
    }

    .fsd-airline-name {
        font-size: 14px;
        font-weight: 500;
        color: var(--text-primary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* Flight number */
    .fsd-fnum {
        font-family: 'Share Tech Mono', monospace;
        font-size: 14px;
        color: var(--accent-amber);
        letter-spacing: .05em;
        font-weight: 600;
    }

    /* Route */
    .fsd-route {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        color: var(--text-primary);
        white-space: nowrap;
    }

    .fsd-route-arrow {
        color: var(--accent-amber);
        font-size: 12px;
        opacity: 0.7;
    }

    .fsd-iata {
        font-family: 'Barlow Condensed', sans-serif;
        font-weight: 700;
        font-size: 16px;
        letter-spacing: .05em;
        color: var(--text-primary);
    }

    .fsd-city {
        font-size: 11px;
        color: var(--text-dim);
    }

    /* Time */
    .fsd-time {
        font-family: 'Share Tech Mono', monospace;
        font-size: 16px;
        color: var(--text-primary);
        letter-spacing: .05em;
    }

    /* Gate / Terminal */
    .fsd-gate, .fsd-terminal {
        font-family: 'Barlow Condensed', sans-serif;
        font-size: 15px;
        font-weight: 600;
        color: var(--text-primary);
        letter-spacing: .05em;
    }

    .fsd-gate-num {
        display: inline-block;
        padding: 2px 8px;
        background: rgba(0, 0, 0, 0.4);
        border: 1px solid var(--border);
        border-radius: 6px;
        font-size: 13px;
        font-weight: 600;
        color: var(--accent-amber);
    }

    /* Status badge */
    .fsd-status {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 5px 12px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: .04em;
        text-transform: uppercase;
        font-family: 'Barlow Condensed', sans-serif;
        white-space: nowrap;
        box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    }

        .fsd-status i {
            font-size: 12px;
        }

    .s-green {
        background: rgba(74, 222, 128, 0.15);
        border: 1px solid rgba(74, 222, 128, 0.35);
        color: var(--s-green);
    }

    .s-blue {
        background: rgba(56, 189, 248, 0.15);
        border: 1px solid rgba(56, 189, 248, 0.35);
        color: var(--s-blue);
    }

    .s-orange {
        background: rgba(251, 146, 60, 0.15);
        border: 1px solid rgba(251, 146, 60, 0.35);
        color: var(--s-orange);
    }

    .s-red {
        background: rgba(248, 113, 113, 0.15);
        border: 1px solid rgba(248, 113, 113, 0.35);
        color: var(--s-red);
    }

    .s-yellow {
        background: rgba(250, 204, 21, 0.15);
        border: 1px solid rgba(250, 204, 21, 0.35);
        color: var(--s-yellow);
    }

    .s-purple {
        background: rgba(192, 132, 252, 0.15);
        border: 1px solid rgba(192, 132, 252, 0.35);
        color: var(--s-purple);
    }

    .s-gray {
        background: rgba(203, 213, 225, 0.12);
        border: 1px solid rgba(203, 213, 225, 0.25);
        color: var(--s-gray);
    }

    /* ── Tab panes ── */
    .fsd-pane {
        display: none;
    }

        .fsd-pane.active {
            display: block;
        }

    /* ── Ticker strip ── */
    .fsd-ticker-wrap {
        margin-top: 24px;
        overflow: hidden;
        border-top: 1px solid var(--border-subtle);
        padding-top: 16px;
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .fsd-ticker-label {
        font-family: 'Share Tech Mono', monospace;
        font-size: 11px;
        letter-spacing: .2em;
        color: var(--accent-amber);
        text-transform: uppercase;
        flex-shrink: 0;
        white-space: nowrap;
    }

    .fsd-ticker-track {
        overflow: hidden;
        flex: 1;
    }

    .fsd-ticker-inner {
        display: flex;
        gap: 48px;
        white-space: nowrap;
        animation: ticker-scroll 28s linear infinite;
    }

    .fsd-ticker-item {
        font-family: 'Share Tech Mono', monospace;
        font-size: 12px;
        color: var(--text-dim);
        letter-spacing: .05em;
        flex-shrink: 0;
    }

        .fsd-ticker-item span {
            color: var(--accent-amber);
            font-weight: 600;
        }

    @@keyframes ticker-scroll {
        0%

    {
        transform: translateX(0);
    }

    100% {
        transform: translateX(-50%);
    }

    }

    /* ── Responsive Mobile ── */
    @@media (max-width: 991px) {
        .fsd-col-headers

    {
        display: none;
    }

    .fsd-flight-row {
        grid-template-columns: 1fr 1fr;
        grid-template-rows: auto;
        gap: 12px 16px;
        padding: 20px;
    }

        .fsd-flight-row > .fsd-cell:nth-child(1) {
            grid-column: 1 / 2;
        }

        .fsd-flight-row > .fsd-cell:nth-child(2) {
            grid-column: 2 / 3;
            justify-content: flex-end;
        }

        .fsd-flight-row > .fsd-cell:nth-child(3) {
            grid-column: 1 / 3;
        }

        .fsd-flight-row > .fsd-cell:nth-child(4) {
            display: none;
        }

        .fsd-flight-row > .fsd-cell:nth-child(5) {
            grid-column: 1 / 2;
        }

        .fsd-flight-row > .fsd-cell:nth-child(6) {
            grid-column: 2 / 3;
            justify-content: flex-end;
        }

        .fsd-flight-row > .fsd-cell:nth-child(7) {
            display: none;
        }

        .fsd-flight-row > .fsd-cell:nth-child(8) {
            grid-column: 1 / 3;
        }

    }

    @@media (max-width: 575px) {
        .fsd-title

    {
        font-size: 26px;
    }

    .fsd-tab-btn {
        padding: 8px 20px;
        font-size: 14px;
    }

    }
</style>

<div class="brand-area brand-bg">
    <div class="fsd-glow-left"></div>
    <div class="container fsd-container">

