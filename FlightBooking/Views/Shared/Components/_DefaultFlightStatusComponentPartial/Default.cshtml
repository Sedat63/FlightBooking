    </div>
</div>


<script>
    /* ────────────────────────────────────────────────
       FLIGHT STATUS DATA & RENDERER (Hata Düzeltildi)
       ──────────────────────────────────────────────── */
    const AIRLINES = [
      { name:'Turkish Airlines', code:'TK', color:'#ff3b30', bg:'rgba(255,255,255,0.12)' },
      { name:'Lufthansa',        code:'LH', color:'#54c7fc', bg:'rgba(255,255,255,0.12)' },
      { name:'British Airways',  code:'BA', color:'#ffcc00', bg:'rgba(255,255,255,0.12)' },
      { name:'Emirates',         code:'EK', color:'#e0b84c', bg:'rgba(255,255,255,0.12)' },
      { name:'Air France',       code:'AF', color:'#34aadc', bg:'rgba(255,255,255,0.12)' },
      { name:'Qatar Airways',    code:'QR', color:'#ff2d55', bg:'rgba(255,255,255,0.12)' },
      { name:'KLM',              code:'KL', color:'#00a1de', bg:'rgba(255,255,255,0.12)' }, // Hata düzeltildi: Tırnak eklendi
      { name:'Swiss Air',        code:'LX', color:'#ff3b30', bg:'rgba(255,255,255,0.12)' },
      { name:'Pegasus',          code:'PC', color:'#ff9500', bg:'rgba(255,255,255,0.12)' },
      { name:'SunExpress',       code:'XQ', color:'#ffcc00', bg:'rgba(255,255,255,0.12)' },
    ];

    const AIRPORTS = [
      { iata:'IST', city:'Istanbul' },
      { iata:'LHR', city:'London'   },
      { iata:'CDG', city:'Paris'    },
      { iata:'FRA', city:'Frankfurt'},
      { iata:'AMS', city:'Amsterdam'},
      { iata:'DXB', city:'Dubai'    },
      { iata:'DOH', city:'Doha'     },
      { iata:'MUC', city:'Munich'   },
      { iata:'MAD', city:'Madrid'   },
      { iata:'FCO', city:'Rome'     },
      { iata:'ZRH', city:'Zurich'   },
      { iata:'BCN', city:'Barcelona'},
      { iata:'JFK', city:'New York' },
      { iata:'DUS', city:'Düsseldorf'},
    ];

    const STATUSES = [
      { label:'Check-in Open',  cls:'s-blue',   icon:'bi-ticket-perforated-fill' },
      { label:'Go to Counter',  cls:'s-blue',   icon:'bi-person-lines-fill'      },
      { label:'Go to Gate',     cls:'s-purple', icon:'bi-signpost-fill'          },
      { label:'Boarding',       cls:'s-orange', icon:'bi-door-open-fill'          },
      { label:'Final Call',     cls:'s-orange', icon:'bi-megaphone-fill'          },
      { label:'Gate Closed',    cls:'s-gray',   icon:'bi-door-closed-fill'        },
      { label:'Departed',       cls:'s-green',  icon:'bi-airplane-fill'           },
      { label:'Landed',         cls:'s-green',  icon:'bi-geo-alt-fill'            },
      { label:'Delayed',        cls:'s-yellow', icon:'bi-clock-history'           },
      { label:'Cancelled',      cls:'s-red',    icon:'bi-x-circle-fill'           },
    ];

    const DEP_STATUSES  = [0,1,2,3,4,5,6,8,9,2];
    const ARR_STATUSES  = [7,7,8,9,6,2,7,8,3,7];

    function pad(n){ return String(n).padStart(2,'0'); }

    function makeTime(offsetMin){
      const d = new Date();
      d.setMinutes(d.getMinutes() + offsetMin);
      return pad(d.getHours()) + ':' + pad(d.getMinutes());
    }

    const OFFSETS_DEP = [-45,-30,-15,5,20,35,50,65,80,95];
    const OFFSETS_ARR = [-60,-40,-20,-5,10,30,45,60,75,90];

    function buildFlights(isArrival){
      const offsets = isArrival ? OFFSETS_ARR : OFFSETS_DEP;
      const statusIdx = isArrival ? ARR_STATUSES : DEP_STATUSES;
      const origin = { iata:'IST', city:'Istanbul' };

      return AIRLINES.map((al, i) => {
        const remote = AIRPORTS[i + (isArrival ? 0 : 1)];
        const from   = isArrival ? remote : origin;
        const to     = isArrival ? origin : remote;
        const fnum   = al.code + String(100 + i * 37).padStart(3,'0');
        const time   = makeTime(offsets[i]);
        const gate   = ['A','B','C','D'][i % 4] + (10 + i * 3);
        const term   = 'T' + ((i % 3) + 1);
        const status = STATUSES[statusIdx[i]];
        return { al, fnum, from, to, time, gate, term, status };
      });
    }

    function renderRow(f){
      return `
      <div class="fsd-flight-row">
        <div class="fsd-cell">
          <div class="fsd-airline">
            <div class="fsd-airline-icon" style="background:${f.al.bg};color:${f.al.color};">
              ${f.al.code}
            </div>
            <div>
              <div class="fsd-airline-name">${f.al.name}</div>
            </div>
          </div>
        </div>
        <div class="fsd-cell">
          <span class="fsd-fnum">${f.fnum}</span>
        </div>
        <div class="fsd-cell">
          <div class="fsd-route">
            <div>
              <div class="fsd-iata">${f.from.iata}</div>
              <div class="fsd-city">${f.from.city}</div>
            </div>
          </div>
        </div>
        <div class="fsd-cell">
          <div class="fsd-route">
            <i class="bi bi-arrow-right fsd-route-arrow"></i>
            <div>
              <div class="fsd-iata">${f.to.iata}</div>
              <div class="fsd-city">${f.to.city}</div>
            </div>
          </div>
        </div>
        <div class="fsd-cell">
          <span class="fsd-time">${f.time}</span>
        </div>
        <div class="fsd-cell">
          <span class="fsd-gate-num">${f.gate}</span>
        </div>
        <div class="fsd-cell">
          <span class="fsd-gate">${f.term}</span>
        </div>
        <div class="fsd-cell">
          <span class="fsd-status ${f.status.cls}">
            <i class="bi ${f.status.icon}"></i>
            ${f.status.label}
          </span>
        </div>
      </div>`;
    }

    function buildStats(flights){
      const total     = flights.length;
      const onTime    = flights.filter(f => !['Delayed','Cancelled'].includes(f.status.label)).length;
      const delayed   = flights.filter(f => f.status.label === 'Delayed').length;
      const cancelled = flights.filter(f => f.status.label === 'Cancelled').length;

      return `
        <div class="fsd-stat"><span class="fsd-stat-dot" style="background:var(--s-blue)"></span>${total} Flights scheduled</div>
        <div class="fsd-stat"><span class="fsd-stat-dot" style="background:var(--s-green)"></span>${onTime} On time</div>
        <div class="fsd-stat"><span class="fsd-stat-dot" style="background:var(--s-yellow)"></span>${delayed} Delayed</div>
        <div class="fsd-stat"><span class="fsd-stat-dot" style="background:var(--s-red)"></span>${cancelled} Cancelled</div>
      `;
    }

    function buildTicker(deps, arrs){
      const items = [
        ...deps.filter(f=>f.status.label==='Boarding').map(f=>`<span class="fsd-ticker-item">🛫 <span>${f.fnum}</span> to ${f.to.iata} — Now Boarding Gate ${f.gate}</span>`),
        ...arrs.filter(f=>f.status.label==='Landed').map(f=>`<span class="fsd-ticker-item">🛬 <span>${f.fnum}</span> from ${f.from.iata} — Landed</span>`),
        ...deps.filter(f=>f.status.label==='Final Call').map(f=>`<span class="fsd-ticker-item">🚨 Final Call: <span>${f.fnum}</span> to ${f.to.iata} — Gate ${f.gate}</span>`),
        ...deps.filter(f=>f.status.label==='Delayed').map(f=>`<span class="fsd-ticker-item">⚠️ <span>${f.fnum}</span> to ${f.to.iata} — Delayed</span>`),
        ...arrs.filter(f=>f.status.label==='Delayed').map(f=>`<span class="fsd-ticker-item">⚠️ <span>${f.fnum}</span> from ${f.from.iata} — Delayed</span>`),
      ];
      const all = [...items, ...items];
      return all.join('');
    }

    document.addEventListener('DOMContentLoaded', () => {
      const deps = buildFlights(false);
      const arrs = buildFlights(true);

      document.getElementById('departures-list').innerHTML = deps.map(renderRow).join('');
      document.getElementById('arrivals-list').innerHTML   = arrs.map(renderRow).join('');
      document.getElementById('fsd-stats-bar').innerHTML   = buildStats(deps);
      document.getElementById('fsd-ticker').innerHTML      = buildTicker(deps, arrs);

      document.querySelectorAll('.fsd-tab-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.fsd-tab-btn').forEach(b => {
            b.classList.remove('active');
            b.setAttribute('aria-selected','false');
          });
          document.querySelectorAll('.fsd-pane').forEach(p => p.classList.remove('active'));

          btn.classList.add('active');
          btn.setAttribute('aria-selected','true');

          const target = btn.dataset.tab;
          document.getElementById('pane-' + target).classList.add('active');

          const flights = target === 'departures' ? deps : arrs;
          document.getElementById('fsd-stats-bar').innerHTML = buildStats(flights);
        });
      });
    });
</script>